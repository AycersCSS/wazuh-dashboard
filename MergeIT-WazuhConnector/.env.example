# Wazuh server base URL (required)
WAZUH_API_URL="https://your-wazuh-server:55000"

# Wazuh service account for internal use (required for customer auth)
# The connector uses this account to query Wazuh on behalf of customers.
WAZUH_API_USERNAME="wazuh-service-account"
WAZUH_API_PASSWORD="wazuh-service-account-password"

# Disable SSL verification for self-signed certificates (optional, default: true)
WAZUH_SSL_VERIFY="false"

# Secret key for signing customer JWTs (required for customer auth)
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="change-me-to-a-random-secret"

# Path to the SQLite database file (optional, default: connector.db)
DATABASE_PATH="connector.db"

# Wazuh indexer / OpenSearch URL (optional, used by /manager route for indexer info)
WAZUH_INDEXER_URL="https://localhost:9200"
