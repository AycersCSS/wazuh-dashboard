# Local development environment variables for the MergeIT Client Portal.
# Copy this file to .env.local and fill in real values.

# 32+ character secret used by iron-session to encrypt the session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PORTAL_COOKIE_PASSWORD=replace-with-a-32-plus-character-random-secret-string

# Absolute or relative path for the SQLite database file. Defaults to ./data/portal.db.
PORTAL_DB_PATH=./data/portal.db

# Public display name shown on the login page.
NEXT_PUBLIC_PORTAL_NAME=MergeIT Client Portal
